<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Promptino.App.PrompterWindow"
        Width="900"
        Height="560"
        MinWidth="480"
        MinHeight="280"
        CanResize="True"
        WindowDecorations="None"
        Focusable="True"
        Background="{DynamicResource PromptinoWindowBackground}"
        RequestedThemeVariant="Dark"
        Title="{DynamicResource PrompterTitle}"
        Icon="/Assets/promptino-icon.ico">
  <Grid>
  <Border x:Name="RootBorder"
          Padding="32"
          CornerRadius="12"
          BorderBrush="{DynamicResource PromptinoOverlayBorder}"
          BorderThickness="1"
          Background="{DynamicResource PromptinoOverlayBackground}">
    <Grid RowDefinitions="Auto,*">
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
        <TextBlock x:Name="FocusHintTextBlock"
                   Text="Prompter focused: Space Play/Pause, R Reset, Up/Down speed"
                   Foreground="{DynamicResource PromptinoTintForeground}"
                   FontSize="12"
                   VerticalAlignment="Center"/>
        <Border x:Name="PausedIndicatorPill"
                Grid.Column="1"
                Background="{DynamicResource PromptinoPausedPillBackground}"
                CornerRadius="12"
                Padding="8,2"
                IsVisible="True"
                VerticalAlignment="Center">
          <TextBlock Text="PAUSED"
                     Foreground="{DynamicResource PromptinoPausedPillForeground}"
                     FontSize="11"
                     FontWeight="Bold"/>
        </Border>
      </Grid>
      <ScrollViewer Grid.Row="1"
                    x:Name="ScriptScrollViewer"
                    ClipToBounds="True"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Hidden">
        <TextBlock x:Name="ScriptTextBlock"
                   FontSize="44"
                   LineHeight="62"
                   Foreground="{DynamicResource PromptinoScriptForeground}"
                   TextWrapping="Wrap" />
      </ScrollViewer>
      <Grid Grid.Row="1" RowDefinitions="3.5*,Auto,6.5*" IsHitTestVisible="False">
        <Panel Grid.Row="1">
          <!-- Highlight Band -->
          <Border x:Name="ReadingGuideHighlightBand"
                  Height="50"
                  Margin="0,-25,0,-25"
                  Background="{DynamicResource PromptinoReadingGuideBand}"
                  IsVisible="False" />
          <!-- Focus Line -->
          <Border x:Name="ReadingGuideFocusLine"
                  Height="2"
                  Background="{DynamicResource PromptinoReadingGuideLine}"
                  IsVisible="False" />
        </Panel>
      </Grid>
    </Grid>
  </Border>
  <Grid Width="24"
        Height="24"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="0,0,2,2">
    <Thumb x:Name="ResizeGrip"
           Cursor="BottomRightCorner"
           Background="Transparent"
           Opacity="0.6"/>
    <Canvas Width="24" Height="24" IsHitTestVisible="False">
      <Line StartPoint="8,22"  EndPoint="22,8"  Stroke="{DynamicResource PromptinoResizeStroke}" StrokeThickness="1.5"/>
      <Line StartPoint="14,22" EndPoint="22,14" Stroke="{DynamicResource PromptinoResizeStroke}" StrokeThickness="1.5"/>
      <Line StartPoint="20,22" EndPoint="22,20" Stroke="{DynamicResource PromptinoResizeStroke}" StrokeThickness="1.5"/>
    </Canvas>
  </Grid>
  </Grid>
</Window>
